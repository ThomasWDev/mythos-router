{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mythos-router.local/schemas/project-policy.schema.json",
  "title": "Mythos project safety policy",
  "description": "Fail-closed repository-local SWD policy stored at .mythos/policy.json.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "block": {
      "$ref": "#/$defs/pathPatterns"
    },
    "confirm": {
      "$ref": "#/$defs/pathPatterns"
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowDeletes": {
          "type": "boolean"
        },
        "maxActions": {
          "type": "integer",
          "minimum": 1,
          "maximum": 500
        },
        "maxActionContentBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200000
        },
        "allowedOperations": {
          "type": "array",
          "maxItems": 4,
          "items": {
            "type": "string",
            "enum": [
              "CREATE",
              "MODIFY",
              "DELETE",
              "READ"
            ]
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "command"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 60
          },
          "command": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        }
      }
    }
  },
  "$defs": {
    "pathPatterns": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 240
      }
    }
  }
}
